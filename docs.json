{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ClínicaWork",
  "colors": {
    "primary": "#14b8a6",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "icons": {
    "library": "lucide"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Agenda",
        "groups": [
          {
            "group": "Visão geral",
            "pages": [
              "agenda",
              "agenda/agendar-paciente",
              "agenda/relatorio-de-performance",
              "agenda/cancelar-agendamento",
              "agenda/mover-agendamento-outro-dia"
            ]
          },
          {
            "group": "Customizações",
            "pages": [
              "agenda/customizar-cores-consultas",
              "agenda/customizar-status-consultas",
              "agenda/customizar-campos-consultas"
            ]
          },
          {
            "group": "Relatórios",
            "pages": [
              "agenda/relatorio-de-performance"
            ]
          }
        ]
      },
      {
        "tab": "Automação do WhatsApp",
        "groups": [
          {
            "group": "Visão geral",
            "pages": [
              "whatsapp",
              "quickstart"
            ]
          },
          {
            "group": "Automações (agenda)",
            "pages": [
              "automacoes/whatsapp-ao-agendar",
              "automacoes/whatsapp-ao-atualizar-status",
              "automacoes/whatsapp-ao-finalizar-consulta",
              "automacoes/whatsapp-confirmar-agenda"
            ]
          }
        ]
      },
      {
        "tab": "Prontuário",
        "groups": [
          {
            "group": "Visão geral",
            "pages": [
              "prontuario"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      },
      {
        "tab": "Financeiro Médico",
        "groups": [
          {
            "group": "Visão geral",
            "pages": [
              "financeiro"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Suporte por WhatsApp",
          "href": "https://dub.sh/suporteclinicawork",
          "icon": "message-circle"
        }
      ]
    },
    "languages": [
      {
        "language": "Português",
        "code": "pt-BR"
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/light.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Sistema para Clínicas",
        "href": "https://clinica.work"
      },
      {
        "label": "Suporte por WhatsApp",
        "href": "https://dub.sh/suporteclinicawork"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Usar o sistema",
      "href": "https://web.clinica.work"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
}